# =============================================================================
# CORE SETTINGS
# =============================================================================

BOND_ASSETS_PATH=assets

# LLMs
BOND_EXPANSION_LLM=openai/gpt-4o-mini
BOND_DISAMBIGUATION_LLM=openai/gpt-4o-mini

# Embeddings
BOND_EMBED_MODEL=ollama/rajdeopankaj/bond-embed-v1-fp16:latest
BOND_EMB_BATCH=16

# =============================================================================
# API ENDPOINTS & KEYS
# =============================================================================

# Ollama (defaults to localhost:11434 if unset)
OLLAMA_API_BASE=http://localhost(or remove IPV4):11434            


# Cloud providers
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# RETRIEVAL (OPTIONAL)
# =============================================================================

BOND_TOPK_EXACT=5
BOND_TOPK_BM25=20
BOND_TOPK_DENSE=50
BOND_TOPK_FINAL=10
BOND_RRF_K=60.0
BOND_EXPANSION=1
BOND_N_EXPANSIONS=3
BOND_RETURN_TRACE=1